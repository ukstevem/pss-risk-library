# pss-risk-library — environment variables
# Copy to `.env` for local `next dev`. Shared secrets (Supabase, gateway URLs)
# are canonical in platform-portal/.env and picked up at deploy time via
# `env_file: ../platform-portal/.env` in docker-compose.app.yml.

# ── Supabase (shared) ──
# Client-side — baked into the bundle at build time (NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=

# Server-side — used by API routes (RPC + privileged reads)
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# ── Risk Library specific ──
# Internal embedding-proxy on platform_net (server-side only; never exposed publicly).
# The proxy applies the nomic search_query:/search_document: prefixes + L2 normalisation
# and forwards to the Orin's Ollama endpoint.
EMBEDDING_PROXY_URL=http://embedding-proxy:8009
